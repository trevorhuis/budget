{
  "name": "api",
  "type": "module",
  "scripts": {
    "build:schemas": "node ./scripts/build-schemas.mjs",
    "predev": "pnpm build:schemas",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "pnpm build:schemas && tsc",
    "start": "node dist/index.js",
    "migrate": "tsx --env-file=.env src/db/migrate.ts",
    "auth:check-schema": "tsx --env-file=.env src/db/checkAuthSchema.ts",
    "seed": "tsx --env-file=.env src/db/seed.ts",
    "test:e2e": "NODE_ENV=test tsx --env-file=.env --test src/**/*.test.ts",
    "format": "prettier . --write"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "@t3-oss/env-core": "^0.13.10",
    "@tanstack/ai": "^0.8.1",
    "@tanstack/ai-openai": "^0.7.1",
    "better-auth": "^1.5.6",
    "csv-parse": "^6.2.1",
    "hono": "^4.12.8",
    "kysely": "^0.28.12",
    "openai": "^6.32.0",
    "pg": "^8.20.0",
    "uuidv7": "^1.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/pg": "^8.18.0",
    "prettier": "3.8.1",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}
